RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_VHOST=/

# Exchange names (must match what the other teams use)
CALENDAR_EXCHANGE=calendar.exchange
PLANNING_EXCHANGE=planning.exchange

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=

# Alternative deployment variable names understood by the service as well.
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=

# Planning-prefixed deployment variable names take precedence when set.
DB_HOST_PLANNING=
DB_PORT_PLANNING=
DB_NAME_PLANNING=
DB_USER_PLANNING=
DB_PASS_PLANNING=

PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# Dashboards
DASHBOARD_PORT=8088
DEMO_PORT=8089

# Microsoft Graph API (Outlook calendar sync)
# Client ID from your Azure app registration (multitenant, delegated Calendars.ReadWrite)
AZURE_CLIENT_ID=
# Client secret from your Azure app registration
AZURE_CLIENT_SECRET=
# Path to the MSAL token cache file produced by auth_setup.py (default: token_cache.json)
TOKEN_CACHE_FILE=token_cache.json

# Per-user token encryption (Fernet symmetric key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Shared secret for POST /api/tokens — Drupal must send this as "Authorization: Bearer <value>"
# Generate any random string, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN_SECRET=

# Base URL for ICS/Webcal calendar feed links returned to non-Outlook users.
# Must be reachable by end-users.  The service always listens on the same port
# as the health server (default 30050).
# Webcal subscriptions: replace http:// with webcal:// in the returned URL.
ICS_BASE_URL=http://localhost:30050

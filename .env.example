RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_VHOST=/

# Exchange names (must match what the other teams use)
CALENDAR_EXCHANGE=calendar.exchange
PLANNING_EXCHANGE=planning.exchange

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# Dashboards
DASHBOARD_PORT=8088
DEMO_PORT=8089

# Microsoft Graph API (Outlook calendar sync)
# Client ID from your Azure app registration (multitenant, delegated Calendars.ReadWrite)
AZURE_CLIENT_ID=
# Client secret from your Azure app registration
AZURE_CLIENT_SECRET=
# Path to the MSAL token cache file produced by auth_setup.py (default: token_cache.json)
TOKEN_CACHE_FILE=token_cache.json

# Per-user token encryption (Fernet symmetric key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Shared secret for POST /api/tokens — Drupal must send this as "Authorization: Bearer <value>"
# Generate any random string, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN_SECRET=